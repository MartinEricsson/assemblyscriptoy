{
  "name": "assemblyscript-toy",
  "version": "1.0.1",
  "description": "An AssemblyScript to WGSL playground",
  "type": "module",
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "build": "vite build",
    "check": "pnpm check:syntax && pnpm check:shaders && pnpm check:bundle",
    "check:bundle": "vite build",
    "check:shaders": "node scripts/check-shader-corpus.mjs",
    "check:syntax": "find src scripts -type f \\( -name '*.js' -o -name '*.mjs' \\) -print0 | xargs -0 -n1 node --check && node --check shader-source.js",
    "dev": "vite",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gasm-compiler/core": "^0.8.1",
    "assemblyscript": "^0.28.9",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "vite": "^8.0.16"
  }
}
